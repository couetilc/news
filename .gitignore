.claude/settings.local.json

# test coverage output
coverage/

# playwright e2e run artifacts (npm run test:e2e — see playwright.config.ts)
test-results/
playwright-report/
.playwright/

# macOS-specific files
.DS_Store

# jetbrains setting folder
.idea/
