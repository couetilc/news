#!/bin/sh
# Secret gate: scan staged changes with gitleaks before every commit.
# Self-contained — the agent container bakes the binary in (version pinned in
# docker/Dockerfile); environments without it warn and continue, with the
# protect-main ruleset and CI as the backstop.
if command -v gitleaks >/dev/null 2>&1; then
	echo "Running gitleaks on staged changes..."
	if gitleaks git --pre-commit --staged --redact --verbose; then
		echo "gitleaks: no secrets detected."
	else
		cat >&2 <<'EOF'
gitleaks found potential secrets in staged files; commit blocked.
Resolve the findings and restage. Bypass (NOT recommended): git commit --no-verify
EOF
		exit 1
	fi
else
	echo "warning: gitleaks not installed; skipping secret scan for this commit" >&2
fi
exit 0
