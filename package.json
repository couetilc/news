{
  "name": "news",
  "type": "module",
  "version": "0.0.1",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "deploy": "astro build && wrangler deploy",
    "test": "vitest run --coverage",
    "test:e2e": "playwright test",
    "astro": "astro",
    "cf-typegen": "wrangler types",
    "db:migrate:local": "wrangler d1 migrations apply NEWS_DB --local",
    "db:migrate:remote": "wrangler d1 migrations apply NEWS_DB --remote"
  },
  "dependencies": {
    "@astrojs/cloudflare": "^13.7.0",
    "@tailwindcss/vite": "^4.3.1",
    "astro": "^6.4.6",
    "fast-xml-parser": "^5.8.0",
    "tailwindcss": "^4.3.1",
    "wrangler": "^4.99.0"
  },
  "overrides": {
    "vite": "^7"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.16.15",
    "@playwright/test": "1.61.0",
    "@vitest/coverage-istanbul": "^4.1.8",
    "happy-dom": "^20.10.4",
    "vitest": "^4.1.8"
  }
}
