---
import { sourceMeta } from '../lib/sources';
import type { Tab } from '../lib/pagination';

interface Props {
	// Source slugs present in the feed, already ordered (see distinctSources).
	sources: string[];
	// The slugs currently filtering the feed; empty means "All".
	active: string[];
	// The currently active tab (#217). Carried into every chip href (and "All")
	// so changing the source filter keeps the reader on the tab they're viewing —
	// without it a chip click on the Read tab silently dropped back to the default
	// Unread tab. Unread is the default, so an href omits ?tab on it for clean URLs.
	tab: Tab;
}

const { sources, active, tab } = Astro.props;
const activeSet = new Set(active);
const allActive = active.length === 0;

// Build a feed URL for the given source selection, mirroring FeedTabs.hrefFor:
// the Read tab is URL-addressable as ?tab=read (set first so the chip and tab
// hrefs share the same param order), then the source filter; the default Unread
// tab omits ?tab and an empty selection drops to the bare path for clean URLs.
function hrefForSources(slugs: Iterable<string>): string {
	const params = new URLSearchParams();
	if (tab === 'read') params.set('tab', 'read');
	for (const s of slugs) params.append('source', s);
	const qs = params.toString();
	return qs ? `/?${qs}` : '/';
}

// "All" clears the source filter but keeps the active tab (#217), so a filtered
// /?tab=read → "All" stays on Read instead of dropping to the Unread default.
const allHref = hrefForSources([]);

// A chip's href toggles its own source within the current selection: a chip
// that's off turns on (adds its slug), one that's on turns off (drops it). With
// JS off these are plain links, so multi-select still works by tapping chips in
// turn. The active tab rides along so a filter change never switches tabs (#217).
function hrefFor(slug: string): string {
	const next = new Set(active);
	if (next.has(slug)) next.delete(slug);
	else next.add(slug);
	return hrefForSources(next);
}

// Shared chip shape: a compact, ruled, small-caps tag in the newspaper voice —
// no rounded pills. Active chips invert to ink; inactive ones are hairline-ruled.
// The drawn border is already each chip's resting affordance (the ruled-box
// idiom, like the read square), so #136 adds only the missing obligation: the
// ink focus-visible ring on the shared base, so both on and off chips show a
// visible keyboard-focus box. <a href> supplies cursor-pointer; hover is on the
// off variant (the on/active chip is the current selection, with no hover move).
const base =
	'inline-flex items-center gap-1.5 border px-2 py-1 font-sans text-[0.65rem] uppercase tracking-wider focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-ink';
const on = `${base} border-ink bg-ink text-paper`;
const off = `${base} border-rule text-ink-soft hover:border-ink hover:text-accent`;
---

<nav aria-label="Filter by source" class="mb-6 flex flex-wrap items-center gap-2">
	<a href={allHref} class={allActive ? on : off} aria-current={allActive ? 'true' : undefined}>All</a>
	{
		sources.map((slug) => {
			const meta = sourceMeta(slug);
			const isActive = activeSet.has(slug);
			return (
				<a
					href={hrefFor(slug)}
					class={isActive ? on : off}
					aria-current={isActive ? 'true' : undefined}
				>
					<span class={`inline-block size-2 ${meta.swatch}`} aria-hidden="true" />
					{meta.name}
				</a>
			);
		})
	}
</nav>
