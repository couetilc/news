---
import type { ItemRow } from '../ingest/db';
import { isoTime, shortDate } from '../lib/format';
import { sourceMeta } from '../lib/sources';

interface Props {
	item: ItemRow;
	// Whether to render the read/unread toggle. The private homepage passes the
	// default (true); the public read-only feed (issue #49) passes false so the
	// row carries no control that POSTs to /api/read — there's no visitor session
	// to own per-item read state, and the server would reject the write anyway.
	interactive?: boolean;
	// The current view (path + query) the toggle should return to after it flips
	// this item, so the active ?source filter + ?unread/?read cursors survive the
	// POST → 303 (#80). Carried as a hidden field and re-validated server-side
	// (safeReturnPath). Defaults to '/', which preserves the old land-on-home
	// behavior for any caller that doesn't pass the current view.
	returnTo?: string;
}

const { item, interactive = true, returnTo = '/' } = Astro.props;
const seconds = item.published_at ?? item.fetched_at;
const source = sourceMeta(item.source);
// The read-state dimming is Connor's private state; on the public feed every
// item reads as fresh, so the row never dims and there's no toggle.
const isRead = interactive && item.read_at !== null;

// One briefing line: headline + agate dateline on the left, a read-state square
// on the right. Read items dim back like continued/back-section matter; the
// square fills with ink (echoing the source swatch) and its form posts the
// opposite state so one tap flips it. The public feed omits the square entirely.
const row = isRead
	? 'flex items-baseline gap-3 border-b border-rule py-2.5 opacity-55'
	: 'flex items-baseline gap-3 border-b border-rule py-2.5';
// The read/unread square is a binary-state control (#132): it owes the four
// interactive-affordance obligations (#129). Resting affordance = the ruled
// square itself (empty border-rule off / filled border-ink bg-ink + ✓ on);
// hover firms the border; both variants now also carry cursor-pointer and the
// ink focus-visible ring so a keyboard reader can see which square is focused.
const squareBase =
	'mt-0.5 grid size-4 shrink-0 cursor-pointer place-items-center border text-[0.6rem] leading-none transition-opacity duration-150 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-ink disabled:cursor-default disabled:opacity-50';
const square = isRead
	? `${squareBase} border-ink bg-ink text-paper`
	: `${squareBase} border-rule text-transparent hover:border-ink`;
const label = isRead ? 'Mark as unread' : 'Mark as read';
const nextState = isRead ? '0' : '1';
---

<li class={row} transition:name={`item-${item.id}`}>
	<div class="min-w-0 flex-1">
		{/* Headline link — the text-link idiom (#129/#131). Resting affordance: per
		    the design-system call, a permanent underline reads heavy on a dense
		    digest, so the underline stays reserved for hover/focus-visible and the
		    layout carries the resting cue — the row is a single tap target and the
		    link is its only serif headline. It still owes the four obligations: the
		    focus-visible ink ring (added here) gives keyboard readers a visible focus
		    box, hover goes accent + underlined, and <a href> supplies cursor-pointer. */}
		<a
			href={item.url}
			class="group block focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-ink"
		>
			<h2
				class="text-base font-semibold leading-snug tracking-tight decoration-from-font underline-offset-2 group-hover:text-accent group-hover:underline group-focus-visible:text-accent group-focus-visible:underline sm:text-lg"
			>
				{item.title}
			</h2>
		</a>
		<p
			class="mt-0.5 flex items-center font-sans text-[0.65rem] uppercase tracking-wider text-muted"
		>
			<span class={`mr-1.5 inline-block size-2 ${source.swatch}`} aria-hidden="true" />
			<span class="font-semibold text-ink-soft">{source.name}</span>
			<span class="mx-1.5" aria-hidden="true">·</span>
			<time datetime={isoTime(seconds)}>{shortDate(seconds)}</time>
		</p>
	</div>
	{
		interactive && (
			/* Read/unread toggle. Progressive enhancement (#96): with JS off this is a
			   plain POST → 303 → reload (the source of truth); the server write is
			   idempotent both ways (DELETE-where to unmark, INSERT…ON CONFLICT DO
			   UPDATE to mark), so a double-POST is harmless even without the client
			   guard. When JS is on, the inline script below disables the square on
			   submit (double-submit defense, client layer) and reveals an in-voice
			   "Working…" agate line where the result lands. */
			<form method="POST" action="/api/read" class="flex items-baseline gap-2" data-read-form>
				<input type="hidden" name="id" value={item.id} />
				<input type="hidden" name="read" value={nextState} />
				<input type="hidden" name="return" value={returnTo} />
				{/* In-voice loading affordance (#96): italic agate "Working…", hidden at
				    rest and revealed by the script while the toggle is in flight — never a
				    SaaS spinner. aria-hidden until shown so it isn't announced at rest. */}
				<span
					data-read-working
					hidden
					aria-hidden="true"
					class="font-sans text-[0.6rem] italic uppercase tracking-wider text-muted"
				>
					Working…
				</span>
				<button type="submit" class={square} aria-label={label}>
					✓
				</button>
			</form>
		)
	}
</li>

{/* Read/unread toggle enhancement (#96), progressive: the no-JS POST → 303 →
   reload is the source of truth (and the /api/read write is idempotent), so this
   only LAYERS feedback on top when JS runs. On submit it disables the square so a
   second click can't double-POST (client layer of the double-submit defense),
   marks it aria-busy, and reveals the in-voice "Working…" agate line. The form
   then either does a full-page navigation (JS-on-but-no-ClientRouter) or is
   swapped by <ClientRouter />; either way the toggled row re-renders fresh from
   the server, which is the completion confirmation. This client script is built
   by Astro's client pipeline, not the SSR module graph the vitest coverage gate
   sees, so it is exercised by the Playwright e2e (e2e/async-feedback.spec.ts),
   not the 100% src/** istanbul gate. */}
<script>
	for (const form of document.querySelectorAll<HTMLFormElement>('form[data-read-form]')) {
		form.addEventListener('submit', () => {
			const button = form.querySelector<HTMLButtonElement>('button[type="submit"]');
			const working = form.querySelector<HTMLElement>('[data-read-working]');
			if (button) {
				// Disable immediately on activation (no flicker delay needed — the
				// square has no label to swap, just goes busy + dimmed via :disabled).
				button.disabled = true;
				button.setAttribute('aria-busy', 'true');
			}
			if (working) {
				working.hidden = false;
				working.removeAttribute('aria-hidden');
			}
		});
	}
</script>
