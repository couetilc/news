---
// The shared signup/login form (issue #40). A plain POST form so it works with
// JavaScript off, in the newspaper voice: a narrow ruled column, small-caps
// labels, no SaaS pills. The submit posts to the page's own URL (action="");
// the page's POST branch handles it and either redirects on success or
// re-renders this with `error` set and a 400.
interface Props {
	// "Sign in" / "Create account" — the heading and the submit button label.
	heading: string;
	submitLabel: string;
	// The present-tense in-flight label the submit swaps to once JS disables it on
	// submit (#96): "Creating account…" / "Signing in…". Server-side this is just
	// inert markup; the client script below reads it off data-busy-label.
	busyLabel: string;
	// Validation/auth error to surface inline above the fields; null when none.
	error: string | null;
	// The email to pre-fill (empty on first render, the submitted value after a
	// failed submit) so the reader doesn't retype it. Never the password — that's
	// never echoed back.
	email: string;
	// The complementary page, e.g. { href: '/login', prompt: 'Already have an
	// account?', label: 'Sign in' }.
	alt: { href: string; prompt: string; label: string };
}

const { heading, submitLabel, busyLabel, error, email, alt } = Astro.props;
---

<section class="mx-auto max-w-sm py-6">
	<h2 class="mb-5 text-center text-2xl">{heading}</h2>

	{
		error && (
			<p
				role="alert"
				class="mb-4 border-l-2 border-accent bg-paper-edge px-3 py-2 font-sans text-sm text-accent"
			>
				{error}
			</p>
		)
	}

	{/* data-astro-reload (issue #124): opt this credential-changing form out of
	    the globally-mounted <ClientRouter /> (Layout.astro). Without it Astro's
	    client router intercepts the submit as a `fetch` (resourceType 'fetch',
	    isNavigationRequest false) instead of a real document navigation. The
	    enhanced-fetch path is the right default for the read/unread toggle, but
	    login/signup mutate cookies/session state and should be boring full-page
	    navigations — the e2e in e2e/auth-signup.spec.ts pins this. */}
	<form method="POST" class="space-y-4" data-astro-reload>
		<div>
			<label
				for="email"
				class="mb-1 block font-sans text-[0.65rem] uppercase tracking-[0.2em] text-muted"
			>
				Email
			</label>
			<input
				id="email"
				name="email"
				type="email"
				value={email}
				required
				autocomplete="email"
				class="w-full border border-rule bg-paper px-3 py-2 font-sans text-ink focus:border-ink focus:outline-none"
			/>
		</div>

		<div>
			<label
				for="password"
				class="mb-1 block font-sans text-[0.65rem] uppercase tracking-[0.2em] text-muted"
			>
				Password
			</label>
			<input
				id="password"
				name="password"
				type="password"
				required
				minlength="8"
				autocomplete="current-password"
				class="w-full border border-rule bg-paper px-3 py-2 font-sans text-ink focus:border-ink focus:outline-none"
			/>
		</div>

		{/* Submit — the action-button idiom (#129/#133): solid ink block (resting
		    affordance), darkening on hover, plus the previously-missing cursor-pointer
		    and ink focus-visible ring for keyboard a11y. The client script (#96) flips
		    disabled + aria-busy and swaps the visible label to the present-tense
		    data-busy-label on submit. With JS off the button stays enabled and reads
		    {submitLabel}; a failed POST re-renders this form server-side with the
		    original label intact, so nothing depends on the swap being reversible. */}
		<button
			type="submit"
			data-auth-submit
			data-busy-label={busyLabel}
			class="w-full cursor-pointer border border-ink bg-ink py-2 font-sans text-sm uppercase tracking-[0.2em] text-paper hover:bg-ink-soft focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-ink disabled:cursor-default disabled:opacity-60"
		>
			{submitLabel}
		</button>
	</form>

	<p class="mt-5 text-center font-sans text-sm text-muted">
		{alt.prompt}{' '}
		{/* Alt link — text-link idiom (#129/#133). Reconciled per the convention:
		    the accent is the INTERACTION color, not a resting decoration, so the link
		    now rests in ink-soft with a hairline underline (its resting affordance)
		    and goes accent on hover/focus. The form-level error block above keeps the
		    accent as its alert key, unchanged. Added the ink focus-visible ring. */}
		<a
			href={alt.href}
			class="text-ink-soft underline underline-offset-2 hover:text-accent focus-visible:text-accent focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-ink"
		>
			{alt.label}
		</a>
	</p>
</section>

{/* Auth submit enhancement (#96), progressive: the no-JS POST → 303 (success) /
   re-render-with-error (failure) path is the source of truth, and the server is
   the double-submit defense (the users.email UNIQUE constraint makes a duplicate
   signup safe, and a duplicate login is harmless). This LAYERS in-flight feedback
   on top when JS runs: on submit the shared initializer disables the button
   (client layer of the double-submit defense), marks it aria-busy, and swaps the
   label to the present-tense data-busy-label so the reader sees the click
   registered. Completion is confirmed by the redirect to the unlocked homepage; a
   failure re-renders this form server-side with the inline role="alert" error (no
   toast, no silent failure). The enhancement is a single delegated `submit`
   listener on `document` (src/scripts/enhance-forms.ts), shared with the
   read-toggle and sign-out — it survives ClientRouter DOM swaps rather than going
   stale on freshly-rendered markup (#155). Pure DOM logic, unit-tested under
   happy-dom (test/enhance-forms.test.ts) inside the 100% src/** gate and covered
   by the Playwright e2e as a behavioral guard. */}
<script>
	import '../scripts/enhance-forms';
</script>
