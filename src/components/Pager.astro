---
import { pageHref, totalPages } from '../lib/pagination';

interface Props {
	// Which section's cursor this pager drives ('unread' or 'read'); used as the
	// query param name so the two sections page independently.
	param: string;
	// The current (already clamped) 1-based page for this section.
	page: number;
	// Total items in this section under the active source filter — drives total
	// pages and whether the pager renders at all.
	total: number;
	// Active source slugs to preserve in every page link (the #41 filter carry).
	sources: string[];
	// The sibling section's param+page, so this pager's links don't reset it.
	sibling: { param: string; page: number } | null;
	// Accessible label for the nav landmark ("Read pages" / "Unread pages").
	label: string;
}

const { param, page, total, sources, sibling, label } = Astro.props;
const pages = totalPages(total);
// A section that fits on one page (≤50 items) needs no pager at all.
const hasPager = pages > 1;
const hasPrev = page > 1;
const hasNext = page < pages;

const link = 'font-sans text-[0.65rem] uppercase tracking-wider text-ink-soft hover:text-accent';
const disabled = 'font-sans text-[0.65rem] uppercase tracking-wider text-rule';
---

{
	hasPager && (
		<nav
			aria-label={label}
			class="mt-4 flex items-center justify-between border-t border-rule pt-3"
		>
			{hasPrev ? (
				<a
					href={pageHref(sources, param, page - 1, sibling)}
					rel="prev"
					class={link}
				>
					← Prev
				</a>
			) : (
				<span class={disabled} aria-hidden="true">
					← Prev
				</span>
			)}
			<span class="font-sans text-[0.65rem] uppercase tracking-[0.2em] text-muted">
				Page {page} of {pages}
			</span>
			{hasNext ? (
				<a
					href={pageHref(sources, param, page + 1, sibling)}
					rel="next"
					class={link}
				>
					Next →
				</a>
			) : (
				<span class={disabled} aria-hidden="true">
					Next →
				</span>
			)}
		</nav>
	)
}
