---
import Layout from '../layouts/Layout.astro';

const now = new Date();
---

<Layout title="News">
	<main class="mx-auto max-w-2xl px-4 py-8 sm:px-6 sm:py-12">
		<h1 class="text-2xl font-bold tracking-tight sm:text-3xl">Hello, news!</h1>
		<p class="mt-3 text-gray-600">
			Your personal news aggregator. Nothing aggregated yet — check back soon.
		</p>
		<p class="mt-1 text-gray-600">edited by dispatch</p>
		<p class="mt-6 text-sm text-gray-400">
			Server-rendered at <time datetime={now.toISOString()}
				>{now.toISOString()}</time
			>
		</p>
	</main>
</Layout>
