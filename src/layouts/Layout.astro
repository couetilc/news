---
import { ClientRouter } from 'astro:transitions';
import '../styles/global.css';
import { longDate } from '../lib/format';

interface Props {
	title: string;
}

const { title } = Astro.props;

// The masthead carries today's date like a printed edition. Built in UTC so the
// dateline is stable wherever the worker runs.
const dateline = longDate(new Date());

// The session control lives in the masthead (issue #128) so it stops taking a
// standalone line above the feed. Layout is shared by every page (/, /login,
// /signup…), so it reads the auth state off Astro.locals.userId — the one typed
// place the middleware sets it (#70) — and renders the matching affordance:
// the POST-to-/logout Sign out form when a user is logged in, a Log in link
// when not. Both follow the interactive-affordance convention (#129): Sign out
// is the action-button idiom, Log in is the text-link idiom.
const isAuthed = Astro.locals.userId !== undefined;
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
		{/* Turns the read/unread form POST → 303 reload into a client-side
		    view-transition navigation, so a toggled item animates from its old
		    slot to its new one (see the transition:name on each Article row).
		    Pure progressive enhancement: with JS off the form does a normal
		    POST + reload, and Astro disables the animation under
		    prefers-reduced-motion. */}
		<ClientRouter />
	</head>
	<body class="min-h-screen antialiased">
		<div class="mx-auto w-full max-w-5xl px-4 sm:px-6 lg:px-8">
			{/* The nameplate stays centered: the session control is taken out of flow
			    (absolute, top-right corner) so it never offsets the centered dateline /
			    "News" / tagline. Mobile-first — it's pinned to the corner at an agate
			    scale that doesn't crowd the narrow masthead, growing only at sm:. */}
			<header
				class="relative border-y-4 border-double border-ink py-3 text-center sm:py-4"
			>
				<div class="absolute right-3 top-2 sm:right-4 sm:top-3">
					{
						isAuthed ? (
							/* Sign out — the action-button idiom (#129): a drawn ink-outline
							   control (resting affordance), accent-filling on hover, a
							   focus-visible ring, cursor-pointer. A plain POST form so it
							   logs out with JS off (POST /logout → 303). data-astro-reload
							   (issue #124): like the signup/login forms, this is a
							   credential/session-changing POST, so it opts out of the
							   globally-mounted ClientRouter above and submits as a real
							   document navigation rather than a client-router fetch. */
							<form method="POST" action="/logout" data-astro-reload>
								<button
									type="submit"
									data-logout-submit
									data-busy-label="Signing out…"
									class="cursor-pointer border border-ink px-2 py-1 font-sans text-[0.6rem] uppercase tracking-[0.2em] text-ink hover:bg-ink hover:text-paper focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-ink disabled:cursor-default disabled:opacity-60 sm:text-xs"
								>
									Sign out
								</button>
							</form>
						) : (
							/* Log in — the text-link idiom (#129): a resting hairline
							   underline, accent on hover, a focus-visible ring. */
							<a
								href="/login"
								class="font-sans text-[0.6rem] uppercase tracking-[0.2em] text-ink-soft underline underline-offset-2 hover:text-accent focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-ink sm:text-xs"
							>
								Log in
							</a>
						)
					}
				</div>
				<p
					class="font-sans text-[0.6rem] uppercase tracking-[0.3em] text-muted sm:text-xs"
				>
					{dateline}
				</p>
				<h1 class="my-0.5 text-4xl leading-none sm:text-5xl">News</h1>
				<p
					class="font-sans text-[0.6rem] uppercase tracking-[0.25em] text-muted sm:text-xs"
				>
					All the feeds fit to print
				</p>
			</header>
			<main class="py-5 sm:py-6">
				<slot />
			</main>
			<footer
				class="border-t border-rule py-6 text-center font-sans text-xs text-muted"
			>
				<p>A personal news aggregator · news.cuteteal.com</p>
			</footer>
		</div>
		{/* Sign-out enhancement (#96), progressive: the no-JS POST /logout → 303 →
		    /login is the source of truth (and POST-only, so a prefetch can't fire
		    it). This LAYERS in-flight feedback when JS runs — on submit the shared
		    initializer disables the button so a second click can't double-POST, marks
		    it aria-busy, and swaps the label to the present-tense data-busy-label.
		    Completion is confirmed by the navigation to /login. The enhancement is a
		    single delegated `submit` listener on `document`
		    (src/scripts/enhance-forms.ts), shared with the read-toggle and auth
		    submit — it survives ClientRouter DOM swaps rather than going stale on
		    freshly-rendered markup (#155). Pure DOM logic, unit-tested under
		    happy-dom (test/enhance-forms.test.ts) inside the 100% src/** gate. */}
		<script>
			import '../scripts/enhance-forms';
		</script>
	</body>
</html>
