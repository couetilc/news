---
import '../styles/global.css';
import { longDate } from '../lib/format';

interface Props {
	title: string;
}

const { title } = Astro.props;

// The masthead carries today's date like a printed edition. Built in UTC so the
// dateline is stable wherever the worker runs.
const dateline = longDate(new Date());
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
	</head>
	<body class="min-h-screen antialiased">
		<div class="mx-auto w-full max-w-5xl px-4 sm:px-6 lg:px-8">
			<header class="border-y-4 border-double border-ink py-3 text-center sm:py-4">
				<p
					class="font-sans text-[0.6rem] uppercase tracking-[0.3em] text-muted sm:text-xs"
				>
					{dateline}
				</p>
				<h1 class="my-0.5 text-4xl leading-none sm:text-5xl">News</h1>
				<p
					class="font-sans text-[0.6rem] uppercase tracking-[0.25em] text-muted sm:text-xs"
				>
					All the feeds fit to print
				</p>
			</header>
			<main class="py-5 sm:py-6">
				<slot />
			</main>
			<footer
				class="border-t border-rule py-6 text-center font-sans text-xs text-muted"
			>
				<p>A personal news aggregator · news.cuteteal.com</p>
			</footer>
		</div>
	</body>
</html>
