#!/bin/bash
# Run Claude Code in an isolated agent container, full-auto.
#
#   ./bin/claude                  interactive session, permissions skipped
#   ./bin/claude -p "fix tests"   headless one-shot, permissions skipped
#   ./bin/claude --shell          bash inside the container instead of claude
#   ./bin/claude --clean          remove exited agent containers
#
# Isolation contract: NOTHING from the host is mounted. The container clones
# the repo fresh from GitHub at launch (so hand it in-progress work by
# committing first — the post-commit hook auto-pushes the branch). Parallel
# containers share nothing but an npm cache. Work leaves the container only
# via git: commits are gitleaks-gated (.git-hooks/pre-commit, binary baked
# into the image) and auto-pushed (.git-hooks/post-commit). Tokens are
# injected as environment variables from .env:
#   CLAUDE_CODE_OAUTH_TOKEN  from `claude setup-token`  (claude auth)
#   GH_TOKEN                 fine-grained PAT            (clone, push, gh)
#   CLOUDFLARE_API_TOKEN     wrangler, if ever needed
#
# Containers are kept after exit (not --rm) so unpushed work is recoverable:
# resume with `docker start -ai <name>` (this begins a NEW claude session in
# the same workspace — use /resume inside to pick up the previous one),
# salvage files with `docker cp`. `./bin/claude --clean` removes exited
# containers and rebuilds the image from scratch so the claude CLI doesn't
# freeze at image-build-time latest.
set -euo pipefail
cd "$(dirname "$0")/.."

if [ "${1:-}" = "--clean" ]; then
	exited=$(docker ps -aq --filter label=news-agent --filter status=exited)
	if [ -n "$exited" ]; then
		docker rm $exited
	else
		echo "no exited agent containers"
	fi
	echo "Rebuilding image from scratch (fresh claude/gh/node)..."
	docker build --pull --no-cache -t news-agent docker/
	exit 0
fi

if [ ! -f .env ]; then
	echo "error: .env not found — copy .env.example and fill in tokens" >&2
	exit 1
fi
if ! grep -q '^GH_TOKEN=.\+' .env; then
	echo "error: GH_TOKEN is empty in .env — the container clones and pushes over HTTPS with it (see .env.example)" >&2
	exit 1
fi

IMAGE=news-agent
docker build -q -t "$IMAGE" docker/ >/dev/null

CMD=(claude --dangerously-skip-permissions --effort xhigh)
if [ "${1:-}" = "--shell" ]; then
	shift
	CMD=(bash)
fi

NAME="news-agent-$(date +%m%d-%H%M%S)"
echo "Starting $NAME (kept after exit; ./bin/claude --clean to prune)" >&2

docker run -it \
	--name "$NAME" \
	--label news-agent \
	-v news-agent-npm-cache:/home/node/.npm \
	--env-file .env \
	-e GIT_USER_NAME="$(git config user.name 2>/dev/null || true)" \
	-e GIT_USER_EMAIL="$(git config user.email 2>/dev/null || true)" \
	-p 127.0.0.1::4321 -p 127.0.0.1::8787 \
	"$IMAGE" "${CMD[@]}" "$@"
