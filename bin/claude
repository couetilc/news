#!/bin/bash
# Run Claude Code in an isolated agent container, full-auto.
#
#   ./bin/claude                  interactive session, permissions skipped
#   ./bin/claude -p "fix tests"   headless one-shot, permissions skipped
#   ./bin/claude --shell          bash inside the container instead of claude
#   ./bin/claude --clean          remove exited agent containers + rebuild image
#
# Auth (from .env): CLAUDE_CODE_OAUTH_TOKEN (claude CLI) + GH_TOKEN (clone/push).
# The shared launcher logic — isolation contract, preflight, sync_main, image
# build, dev-server port mapping, docker run — lives in bin/_agent-common.sh.
set -euo pipefail

AGENT_KIND=claude

# CLAUDE_CODE_OAUTH_TOKEN (host `claude setup-token`, billed to the Claude
# subscription) authenticates the CLI inside the container, injected via .env.
agent_auth_preflight() {
	grep -q '^CLAUDE_CODE_OAUTH_TOKEN=.\+' .env || {
		echo "error: CLAUDE_CODE_OAUTH_TOKEN is empty in .env — claude authenticates with it inside the container (see .env.example)" >&2
		exit 1
	}
}

# Interactive default and `-p` headless both run `claude`; `-p` is a native
# claude flag, so the user's args pass straight through. (CMD is consumed by
# agent_launch in the sourced common script.)
# shellcheck disable=SC2034  # CMD is read by agent_launch (bin/_agent-common.sh)
agent_cmd() {
	CMD=(claude --dangerously-skip-permissions --model opus --effort xhigh "$@")
}

# shellcheck source=bin/_agent-common.sh
source "$(dirname "$0")/_agent-common.sh"
agent_launch "$@"
