#!/bin/bash
# Run OpenAI Codex in an isolated agent container, full-auto — parity with
# ./bin/claude: same isolation contract, flags, and lifecycle; it just runs
# `codex` instead of `claude`.
#
#   ./bin/codex                   interactive session, approvals+sandbox bypassed
#   ./bin/codex -p "fix tests"    headless one-shot (codex exec)
#   ./bin/codex --shell           bash inside the container instead of codex
#   ./bin/codex --clean           remove exited agent containers + rebuild image
#
# Model/effort: gpt-5.5 at xhigh reasoning effort — mirrors bin/claude's
# opus/xhigh. gpt-5.5 is OpenAI's current flagship; bump CODEX_MODEL when a
# smarter id ships.
#
# Auth — uses your ChatGPT *subscription*, not pay-as-you-go API billing, for
# parity with bin/claude (which bills the Claude subscription via
# CLAUDE_CODE_OAUTH_TOKEN). One-time host setup: run `codex login` once on this
# machine (browser OAuth against your ChatGPT plan). That writes
# ~/.codex/auth.json; this launcher reads it and injects it into the container
# (the ChatGPT browser login can't run under the no-host-mount contract). No
# Codex credential goes in .env. Fallback: set OPENAI_API_KEY in .env to bill
# pay-as-you-go API usage instead (see .env.example). GH_TOKEN (clone/push)
# still comes from .env. Shared launcher logic lives in bin/_agent-common.sh.
set -euo pipefail

AGENT_KIND=codex
CODEX_MODEL=gpt-5.5
# Forward the model id so the entrypoint's config.toml fallback matches the flag.
AGENT_ENV=(-e CODEX_MODEL="$CODEX_MODEL")

# Inject the host's subscription credential when present. auth.json is multi-line
# JSON (--env-file can't carry it) and secret, so base64 it into an exported var
# and pass it through with a bare `-e CODEX_AUTH_B64` — keeping it off the
# `docker run` argv (and out of `ps`). `base64 | tr -d '\n'` is portable across
# the macOS host and the Linux container; the entrypoint decodes it. Done
# unconditionally (not gated on --shell) so a --shell session is authed too.
CODEX_AUTH_FILE="${CODEX_HOME:-$HOME/.codex}/auth.json"
if [ -f "$CODEX_AUTH_FILE" ]; then
	CODEX_AUTH_B64="$(base64 < "$CODEX_AUTH_FILE" | tr -d '\n')"
	export CODEX_AUTH_B64
	AGENT_ENV+=(-e CODEX_AUTH_B64)
fi

agent_append_env_args() {
	# shellcheck disable=SC2154  # docker_args is local to agent_launch; Bash dynamic scoping makes it visible here.
	docker_args+=("${AGENT_ENV[@]}")
}

# A real launch needs a credential: the injected subscription auth above, or an
# OPENAI_API_KEY fallback in .env. (--shell skips this — see common script.)
agent_auth_preflight() {
	if [ -z "${CODEX_AUTH_B64:-}" ] && ! grep -q '^OPENAI_API_KEY=.\+' .env; then
		echo "error: no Codex credential found." >&2
		echo "  Recommended: run \`codex login\` on this host once (uses your ChatGPT subscription)." >&2
		echo "  Or set OPENAI_API_KEY in .env for pay-as-you-go API billing (see .env.example)." >&2
		exit 1
	fi
}

# `--dangerously-bypass-approvals-and-sandbox` (alias --yolo) is the codex analog
# of claude's --dangerously-skip-permissions: no approvals, no sandbox — the
# container *is* the sandbox. Reasoning effort is a config override quoted as a
# TOML string; passing it as a flag is the reliable source of truth (config.toml
# effort can be ignored on a fresh launch — openai/codex#17436). `-p` maps to the
# `codex exec` non-interactive subcommand (codex has no `-p` flag).
# shellcheck disable=SC2034  # CMD is read by agent_launch (bin/_agent-common.sh)
agent_cmd() {
	local flags=(--dangerously-bypass-approvals-and-sandbox --model "$CODEX_MODEL" --config 'model_reasoning_effort="xhigh"')
	if [ "${1:-}" = "-p" ]; then
		shift
		CMD=(codex exec "${flags[@]}" "$@")
	else
		CMD=(codex "${flags[@]}" "$@")
	fi
}

# shellcheck source=bin/_agent-common.sh
source "$(dirname "$0")/_agent-common.sh"
agent_launch "$@"
